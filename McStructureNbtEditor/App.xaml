<Application x:Class="McStructureNbtEditor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:McStructureNbtEditor"
             xmlns:converters="clr-namespace:McStructureNbtEditor.ViewModels.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Lang/en-US.xaml"/>
                <ResourceDictionary Source="Resources/Lang/ko-KR.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <converters:BlockToBrushConverter x:Key="BlockToBrushConverter"
                                              AirBrush="WhiteSmoke"
                                              Saturation="0.3"
                                              Value="0.90" />
        </ResourceDictionary>
    </Application.Resources>
</Application>