<Window x:Class="McStructureNbtEditor.Views.HasChangesDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="RootWindow"
        Title="{DynamicResource L_Dialog_TitleSaveModified}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Width="400"
        MinHeight="160"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding Message}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="{DynamicResource L_Dialog_ButtonSave}"
                    Width="96"
                    Height="28"
                    Margin="10,0,10,0"
                    Command="{Binding SaveCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}"/>
            <Button Content="{DynamicResource L_Dialog_ButtonDontSave}"
                    Width="96"
                    Height="28"
                    Margin="10,0,10,0"
                    Command="{Binding ExitCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}"/>
            <Button Content="{DynamicResource L_Dialog_ButtonCancel}"
                    Width="96"
                    Height="28"
                    Margin="10,0,10,0"
                    Command="{Binding CancelCommand}"
                    CommandParameter="{Binding ElementName=RootWindow}"/>
        </StackPanel>
    </Grid>
</Window>