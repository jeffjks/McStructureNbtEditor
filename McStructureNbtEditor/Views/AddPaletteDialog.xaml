<Window x:Class="McStructureNbtEditor.Views.AddPaletteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Palette"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="팔레에 추가할 블록 이름을 작성하세요" Margin="0,0,0,8"/>
        <TextBox Grid.Row="1"
                 Width="280"
                 Height="24"
                 Text="{Binding PaletteName, UpdateSourceTrigger=PropertyChanged}" />

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,12,0,0">
            <Button Content="확인"
                    Width="80"
                    Height="24"
                    Margin="8,0,8,0"
                    IsDefault="True"
                    Click="OkButton_Click"/>
            <Button Content="취소"
                    Width="80"
                    Height="24"
                    Margin="8,0,8,0"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>