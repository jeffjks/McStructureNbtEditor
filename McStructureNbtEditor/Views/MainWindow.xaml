<Window x:Class="McStructureNbtEditor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:McStructureNbtEditor"
    xmlns:models="clr-namespace:McStructureNbtEditor.Models"
    xmlns:views="clr-namespace:McStructureNbtEditor.Views"
    xmlns:viewmodels="clr-namespace:McStructureNbtEditor.ViewModels"
    mc:Ignorable="d"
    Title="Minecraft Structure NBT Editor"
    Height="700" Width="1100"
    d:DataContext="{d:DesignInstance viewmodels:MainViewModel}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Background="White">
            <MenuItem Header="파일(_F)">
                <MenuItem Header="열기(_O)" Command="{Binding OpenFileCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />
                <MenuItem Header="저장(_S)" Command="{Binding SaveFileCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="다른 이름으로 저장(_A)..." Command="{Binding SaveAsFileCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem Header="종료(_X)" Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="도움말(_H)">
                <MenuItem Header="정보" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="8"
                Margin="0,0,8,0">
                <TreeView ItemsSource="{Binding RootNodes}">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type models:NbtTreeNode}"
                            ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                <TextBlock Text=": " />
                                <TextBlock Text="{Binding ValuePreview}" Foreground="DarkBlue" />
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="8">

                <Grid Grid.Column="1" Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                        Text="{Binding LayerSlice.SliceInfoText}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Margin="0,0,0,8" />

                    <Border Grid.Row="1"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="8"
                        Background="#FFF8F8F8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              FocusVisualStyle="{x:Null}"
              CanContentScroll="False">
                            <views:LayerSliceView DataContext="{Binding LayerSlice}" />
                        </ScrollViewer>
                    </Border>

                    <TextBlock Grid.Row="2"
                        Margin="0,8,0,0"
                        Foreground="Gray" />
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,8">
                        <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" FontSize="14" />
                    </ScrollViewer>

                    <Border Grid.Row="1" BorderBrush="LightGray" BorderThickness="0,1,0,0"
                        Padding="0,8,0,0">
                        <Grid Grid.Column="2" Margin="0,8,0,8" Width="220">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                Text="Y 층"
                                FontSize="14"
                                HorizontalAlignment="Center"
                                FontWeight="SemiBold"
                                Margin="0,0,0,8" />

                            <Slider Grid.Row="1"
                                Minimum="{Binding LayerSlice.MinY}"
                                Maximum="{Binding LayerSlice.MaxY}"
                                Value="{Binding LayerSlice.CurrentY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True" />

                            <Grid Grid.Row="2" Margin="0,6,0,0" Height="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                    Text="{Binding LayerSlice.MinLayerLabel}"
                                    HorizontalAlignment="Left"
                                    FontSize="12"
                                    Foreground="Gray" />

                                <TextBlock Grid.Column="1"
                                    Text="{Binding LayerSlice.MaxLayerLabel}"
                                    HorizontalAlignment="Right"
                                    FontSize="12"
                                    Foreground="Gray" />
                            </Grid>
                            <Grid Grid.Row="3" Margin="0,10,0,0" HorizontalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="0"
                                    Content="-"
                                    Width="32"
                                    Height="28"
                                    Command="{Binding LayerSlice.DecreaseYCommand}" />

                                <TextBox Grid.Column="1"
                                    Width="70"
                                    Height="28"
                                    Margin="8,0"
                                    Text="{Binding LayerSlice.CurrentYText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    VerticalContentAlignment="Center"
                                    HorizontalContentAlignment="Center" />

                                <Button Grid.Column="2"
                                    Content="+"
                                    Width="32"
                                    Height="28"
                                    Command="{Binding LayerSlice.IncreaseYCommand}" />
                            </Grid>
                            <Button Grid.Row="4"
                                Margin="0,8,0,0"
                                Height="30"
                                Content="Y 적용"
                                Command="{Binding LayerSlice.ApplyYTextCommand}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2">
            <TextBlock Text="{Binding StatusText}" />
        </StatusBar>
    </Grid>
</Window>