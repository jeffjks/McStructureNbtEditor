<Window x:Class="McStructureNbtEditor.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:McStructureNbtEditor"
    xmlns:models="clr-namespace:McStructureNbtEditor.Models"
    xmlns:views="clr-namespace:McStructureNbtEditor.Views"
    xmlns:viewmodels="clr-namespace:McStructureNbtEditor.ViewModels"
    mc:Ignorable="d"
    Title="Minecraft Structure NBT Editor"
    Width="1200" Height="800"
    MinWidth="1200" MinHeight="800"
    d:DataContext="{d:DesignInstance viewmodels:MainViewModel}">
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="Z" Command="{Binding UndoCommand}" />
        <KeyBinding Modifiers="Control" Key="Y" Command="{Binding RedoCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Background="White">
            <MenuItem Header="파일(_F)">
                <MenuItem Header="열기(_O)" Command="{Binding OpenFileCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xED25;" FontFamily="Segoe MDL2 Assets"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />
                <MenuItem Header="저장(_S)" Command="{Binding SaveFileCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="다른 이름으로 저장(_A)..." Command="{Binding SaveAsFileCommand}">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE792;" FontFamily="Segoe MDL2 Assets"
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem Header="종료(_X)" Command="{Binding ExitCommand}" />
            </MenuItem>

            <MenuItem Header="도움말(_H)">
                <MenuItem Header="정보" />
            </MenuItem>
        </Menu>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Padding="8"
                Margin="0,0,4,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*" />
                        <RowDefinition Height="1*" />
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <Button DockPanel.Dock="Bottom"
                            Content="{DynamicResource L_JumpToBlock}"
                            Margin="0,5,0,20"
                            Padding="20,5"
                            HorizontalAlignment="Center"
                            Command="{Binding NbtTree.JumpToTreeSelectedBlockCommand}"/>
                        <TreeView Grid.Row="0" ItemsSource="{Binding NbtTree.RootNodes}" SelectedItemChanged="TreeView_SelectedItemChanged">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.Resources>
                                <HierarchicalDataTemplate DataType="{x:Type models:NbtTreeNode}"
                                ItemsSource="{Binding Children}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                        <TextBlock Text=": " />
                                        <TextBlock Text="{Binding ValuePreview}" Foreground="DarkBlue" />
                                    </StackPanel>
                                </HierarchicalDataTemplate>
                            </TreeView.Resources>
                        </TreeView>
                    </DockPanel>
                    <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1">
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="4,0,0,0">
                            <TextBlock Text="{Binding SummaryText}" TextWrapping="Wrap" Padding="0,0,4,0" FontSize="14" />
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="4,0,4,0">
                <Grid Grid.Column="1" Margin="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="{Binding LayerSlice.SelectionText}"
                               Margin="0,0,0,4"
                               FontSize="14" />
                    <Border Grid.Row="1"
                        BorderBrush="Gray"
                        BorderThickness="1"
                        Padding="8"
                        Background="#FFF8F8F8">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            FocusVisualStyle="{x:Null}"
                            CanContentScroll="False">
                            <views:LayerSliceView DataContext="{Binding LayerSlice}" />
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Row="2" Padding="0,8,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="12,0,4,0">
                                <Button Content="변경" MinWidth="96" Height="28" Margin="5"/>
                                <Button Content="스포이드" MinWidth="96" Height="28" Margin="5"/>
                                <Button Content="삭제" MinWidth="96" Height="28" Margin="5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="2" BorderBrush="Gray" BorderThickness="1" Padding="8" Margin="4,0,0,0">
                <views:EditPanelView/>
            </Border>
        </Grid>

        <StatusBar Grid.Row="2">
            <TextBlock Text="{Binding Session.StatusMessage}" />
        </StatusBar>
    </Grid>
</Window>