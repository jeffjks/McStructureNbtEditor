<UserControl x:Class="McStructureNbtEditor.Views.EditPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:McStructureNbtEditor.Views"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0" 
             Margin="0,0,0,8"
             Text="{Binding SnbtField.DisplayedSnbt, Mode=TwoWay, UpdateSourceTrigger=Explicit}"
             IsReadOnly="True"
             AcceptsReturn="True"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             VerticalContentAlignment="Top"
             Padding="5"
             SpellCheck.IsEnabled="False"
             FontFamily="Consolas"/>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="0,8,0,0">
        </Border>

        <Border Grid.Row="2" BorderBrush="LightGray" BorderThickness="0,1,0,0" Padding="0,8,0,0">
            <Grid Grid.Column="2" Margin="12,8,12,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                    Text="Y 높이"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    FontWeight="SemiBold"
                    Margin="0,0,0,8" />

                <Slider Grid.Row="1"
                    Minimum="{Binding LayerSlice.MinY}"
                    Maximum="{Binding LayerSlice.MaxY}"
                    Value="{Binding LayerSlice.CurrentY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    TickFrequency="1"
                    IsSnapToTickEnabled="True" />

                <Grid Grid.Row="2" Margin="0,6,0,0" Height="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                        Text="{Binding LayerSlice.MinLayerLabel}"
                        HorizontalAlignment="Left"
                        FontSize="12"
                        Foreground="Gray" />

                    <TextBlock Grid.Column="1"
                        Text="{Binding LayerSlice.MaxLayerLabel}"
                        HorizontalAlignment="Right"
                        FontSize="12"
                        Foreground="Gray" />
                </Grid>
                <Grid Grid.Row="3" Margin="0,10,0,0" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                        Content="-"
                        Width="32"
                        Height="28"
                        Command="{Binding LayerSlice.DecreaseYCommand}" />

                    <TextBox Grid.Column="1"
                        Width="70"
                        Height="28"
                        Margin="8,0"
                        Text="{Binding LayerSlice.CurrentYText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Center" />

                    <Button Grid.Column="2"
                        Content="+"
                        Width="32"
                        Height="28"
                        Command="{Binding LayerSlice.IncreaseYCommand}" />
                </Grid>
                <Button Grid.Row="4"
                    Margin="0,8,0,0"
                    Height="30"
                    MaxWidth="120"
                    Content="Y 적용"
                    Command="{Binding LayerSlice.ApplyYTextCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
