<Window x:Class="McStructureNbtEditor.Views.CommonDialogView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:McStructureNbtEditor.ViewModels.Converters"
        Title="{Binding Title}"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        MinWidth="360"
        MinHeight="160"
        ResizeMode="NoResize">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="{Binding Message}"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"
                   FontSize="14"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="확인"
                    Width="96"
                    Height="28"
                    Margin="10,0,10,0"
                    Command="{Binding ConfirmCommand}"/>
            <Button Content="취소"
                    Width="96"
                    Height="28"
                    Margin="10,0,10,0"
                    Command="{Binding CancelCommand}"
                    Visibility="{Binding VisibleCancel, Converter={StaticResource BoolToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Window>